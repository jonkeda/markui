{
  "brackets": [
    ["[", "]"],
    ["<", ">"],
    ["{", "}"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "<", "close": ">" },
    { "open": "{", "close": "}" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    { "open": "[", "close": "]" },
    { "open": "<", "close": ">" },
    { "open": "{", "close": "}" },
    { "open": "(", "close": ")" },
    { "open": "_", "close": "_" }
  ],
  "folding": {
    "markers": {
      "start": "^\\s*\\+---",
      "end": "^\\s*\\+--\\+"
    }
  }
}
