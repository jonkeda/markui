{
  "Login Form": {
    "prefix": "login",
    "description": "Login form wireframe",
    "body": [
      "+--- ${1:Login} ---+",
      "|                   |",
      "| Username          |",
      "| <${2:username}    >|",
      "|                   |",
      "| Password          |",
      "| <${3:********}    >|",
      "|                   |",
      "| [${4:x}] Remember me |",
      "|                   |",
      "| [${5:Sign In}]       |",
      "|                   |",
      "+-------------------+"
    ]
  },
  "Form Field": {
    "prefix": "field",
    "description": "Form field with label, input, and help annotation",
    "body": [
      "${1:Label}",
      "<${2:placeholder}     >",
      "(?) ${3:Help text for this field}"
    ]
  },
  "Tab Bar": {
    "prefix": "tabs",
    "description": "Tab bar with active tab and content area",
    "body": [
      "+--- ${1:Panel} ---+",
      "| [[${2:Tab 1}]] [${3:Tab 2}] [${4:Tab 3}] |",
      "|---${5:---}------|",
      "| ${6:Tab content}  |",
      "|              |",
      "+--------------+"
    ]
  },
  "Vertical List": {
    "prefix": "vlist",
    "description": "Vertical list container",
    "body": [
      "v--- ${1:Item} ---v",
      "| ${2:Content}       |",
      "| [${3:Action}]      |",
      "v-----------------v"
    ]
  },
  "Horizontal List": {
    "prefix": "hlist",
    "description": "Horizontal list container",
    "body": [
      ">--- ${1:Item} --->",
      "| ${2:Content}      |",
      ">----------------->"
    ]
  },
  "Dock Layout": {
    "prefix": "dock",
    "description": "Dock layout with header, sidebar, main, and footer",
    "body": [
      "+--- ${1:App} -------------------------+",
      "| # ${2:Header}                         |",
      "|--+-------------------------------|",
      "| ${3:Nav}  | ${4:Main content}             |",
      "|      |                           |",
      "|      |                           |",
      "|--+-------------------------------|",
      "| ${5:Footer}                           |",
      "+---------------------------------+"
    ]
  },
  "Data Table": {
    "prefix": "table",
    "description": "Data table with header and rows",
    "body": [
      "+--- ${1:Table} ---+",
      "| ${2:Name}  | ${3:Value} | ${4:Status} |",
      "|--------|-------|--------|",
      "| ${5:Row 1} | ${6:100}   | (${7:Active}) |",
      "| ${8:Row 2} | ${9:200}   | (${10:Pending})|",
      "+--------------------+"
    ]
  },
  "Dropdown Expanded": {
    "prefix": "dropdown",
    "description": "Expanded dropdown with options",
    "body": [
      "<${1:Select option} v>",
      "+------------------+",
      "| ${2:Option 1}        |",
      "| ${3:Option 2}        |",
      "| ${4:Option 3}        |",
      "+------------------+"
    ]
  },
  "Accordion": {
    "prefix": "accordion",
    "description": "Accordion with expanded and collapsed sections",
    "body": [
      "+--- ${1:Accordion} ---+",
      "| [v] ${2:Section 1}    |",
      "|   ${3:Expanded content}|",
      "|                    |",
      "| [>] ${4:Section 2}    |",
      "| [>] ${5:Section 3}    |",
      "+--------------------+"
    ]
  },
  "Toast Notification": {
    "prefix": "toast",
    "description": "Toast notification message",
    "body": [
      "+--- ${1:(v)} ${2:Success} ---+",
      "| ${3:Operation completed}  |",
      "| ${4:successfully.}        |",
      "+----------------------+"
    ]
  }
}
