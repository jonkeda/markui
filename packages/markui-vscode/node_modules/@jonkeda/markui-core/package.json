{
  "name": "@jonkeda/markui-core",
  "version": "0.1.0",
  "description": "MarkUI wireframe parser and renderer",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "visual": "pnpm run visual:svg && pnpm run visual:gallery",
    "visual:svg": "vitest run src/renderer/svg-sanity.test.ts",
    "visual:gallery": "pnpm run build && node ../../scripts/generate-visual-gallery.cjs"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "files": ["dist"],
  "license": "MIT"
}
