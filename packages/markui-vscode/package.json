{
  "name": "markui-vscode",
  "displayName": "MarkUI",
  "description": "IDE support for MarkUI wireframe diagrams",
  "version": "0.1.0",
  "publisher": "jonkeda",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:markui"
  ],
  "contributes": {
    "languages": [
      {
        "id": "markui",
        "aliases": [
          "MarkUI",
          "markui"
        ],
        "extensions": [
          ".markui"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "markui",
        "scopeName": "source.markui",
        "path": "./syntaxes/markui.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "markui",
        "path": "./snippets/markui.json"
      }
    ],
    "markdown.markdownItPlugins": true,
    "markdown.previewScripts": [
      "./dist/markdown-preview.js"
    ],
    "notebookRenderer": [
      {
        "id": "jonkeda.markdown-it.markui-extension",
        "displayName": "MarkUI Notebook Renderer",
        "entrypoint": "./dist/notebook-renderer.js",
        "mimeTypes": [
          "text/markdown"
        ]
      }
    ],
    "commands": [
      {
        "command": "markui.preview",
        "title": "MarkUI: Open Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "markui.exportSvg",
        "title": "MarkUI: Export to SVG"
      },
      {
        "command": "markui.changeTheme",
        "title": "MarkUI: Change Preview Theme"
      },
      {
        "command": "markui.zoomIn",
        "title": "MarkUI: Zoom In"
      },
      {
        "command": "markui.zoomOut",
        "title": "MarkUI: Zoom Out"
      },
      {
        "command": "markui.zoomReset",
        "title": "MarkUI: Reset Zoom"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markui.preview",
          "when": "resourceLangId == markui",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "markui.exportSvg",
          "when": "resourceLangId == markui"
        }
      ]
    },
    "keybindings": [
      {
        "command": "markui.preview",
        "key": "ctrl+shift+v",
        "when": "resourceLangId == markui"
      },
      {
        "command": "markui.zoomIn",
        "key": "ctrl+=",
        "when": "markui.previewFocused"
      },
      {
        "command": "markui.zoomOut",
        "key": "ctrl+-",
        "when": "markui.previewFocused"
      },
      {
        "command": "markui.zoomReset",
        "key": "ctrl+0",
        "when": "markui.previewFocused"
      }
    ],
    "configuration": {
      "title": "MarkUI",
      "properties": {
        "markui.defaultTheme": {
          "type": "string",
          "default": "clean",
          "enum": [
            "clean",
            "sketch",
            "blueprint"
          ],
          "description": "Default theme for MarkUI previews."
        },
        "markui.previewAutoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh the preview when the document changes."
        },
        "markui.validateOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Validate MarkUI files on save."
        },
        "markui.autoPreview": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the preview when a MarkUI file is opened."
        }
      }
    }
  },
  "dependencies": {
    "@jonkeda/markui-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  },
  "scripts": {
    "build": "node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "tsc --noEmit"
  }
}
