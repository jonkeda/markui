{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MarkUI",
  "scopeName": "source.markui",
  "patterns": [
    { "include": "#box-border-titled" },
    { "include": "#card-border-titled" },
    { "include": "#box-border" },
    { "include": "#vertical-border" },
    { "include": "#heading" },
    { "include": "#annotation" },
    { "include": "#active-tab" },
    { "include": "#checkbox" },
    { "include": "#button" },
    { "include": "#dropdown" },
    { "include": "#input" },
    { "include": "#toggle" },
    { "include": "#badge" },
    { "include": "#radio" },
    { "include": "#tag" },
    { "include": "#link" },
    { "include": "#icon" },
    { "include": "#image" },
    { "include": "#separator" },
    { "include": "#component-ref" },
    { "include": "#slot" },
    { "include": "#table-divider" }
  ],
  "repository": {
    "box-border-titled": {
      "match": "(\\+---\\s*)(.+?)(\\s*---+\\+)",
      "captures": {
        "1": { "name": "markup.heading.markui" },
        "2": { "name": "entity.name.section.markui" },
        "3": { "name": "markup.heading.markui" }
      }
    },
    "card-border-titled": {
      "match": "(\\*---\\s*)(.+?)(\\s*---+\\*)",
      "captures": {
        "1": { "name": "markup.heading.markui" },
        "2": { "name": "entity.name.section.markui" },
        "3": { "name": "markup.heading.markui" }
      }
    },
    "box-border": {
      "match": "\\+[-]+\\+",
      "name": "markup.heading.markui"
    },
    "vertical-border": {
      "match": "^\\s*\\|",
      "name": "markup.heading.markui"
    },
    "heading": {
      "match": "^(#{1,3})\\s+(.*)",
      "captures": {
        "1": { "name": "markup.heading.markui" },
        "2": { "name": "entity.name.section.markui" }
      }
    },
    "annotation": {
      "match": "^\\s*(\\(\\?\\)|\\(\\$\\)|\\(!\\)|\\(i\\)|\\(x\\)|\\(v\\))\\s*(.*)",
      "captures": {
        "1": { "name": "keyword.control.markui" },
        "2": { "name": "comment.markui" }
      }
    },
    "active-tab": {
      "match": "\\[\\[([^\\]]+)\\]\\]",
      "name": "entity.name.function.markui"
    },
    "checkbox": {
      "match": "\\[([ x\\-])\\]",
      "name": "keyword.operator.markui"
    },
    "button": {
      "match": "\\[([^\\[\\]]+)\\]",
      "name": "entity.name.function.markui"
    },
    "dropdown": {
      "match": "<(.+?)\\s+([v^])>",
      "captures": {
        "1": { "name": "string.markui" },
        "2": { "name": "keyword.operator.markui" }
      }
    },
    "input": {
      "match": "<([^>]+)>",
      "name": "string.markui"
    },
    "toggle": {
      "match": "\\{(\\[?[^}]+\\]?)/(\\[?[^}]+\\]?)\\}",
      "name": "constant.language.markui"
    },
    "badge": {
      "match": "\\{([0-9]+|!)\\}",
      "name": "constant.numeric.markui"
    },
    "radio": {
      "match": "\\((\\*| )\\)",
      "name": "keyword.operator.markui"
    },
    "tag": {
      "match": "\\(([^()]+)\\)",
      "name": "entity.name.tag.markui"
    },
    "link": {
      "match": "_([^_]+)_",
      "name": "markup.underline.link.markui"
    },
    "icon": {
      "match": "#(\\d+)",
      "name": "constant.character.markui"
    },
    "image": {
      "match": "!([=]+[^!]*[=]+)!",
      "name": "string.regexp.markui"
    },
    "separator": {
      "match": "^\\s*---+\\s*$",
      "name": "comment.line.markui"
    },
    "component-ref": {
      "match": "^\\s*@([a-zA-Z][a-zA-Z0-9_-]*)",
      "name": "variable.other.markui"
    },
    "slot": {
      "match": "\\{@slot(:[a-zA-Z][a-zA-Z0-9_-]*)?\\}",
      "name": "variable.parameter.markui"
    },
    "table-divider": {
      "match": "^\\s*\\|[-|]+\\|\\s*$",
      "name": "comment.line.markui"
    }
  }
}
